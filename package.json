{
  "name": "maase-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@maase/api",
    "dev:cook": "turbo run dev --filter=@maase/cook-dashboard",
    "dev:web": "turbo run dev --filter=@maase/web",
    "dev:app": "turbo run dev --filter=@maase/customer-app",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
