{
  "expo": {
    "name": "Maase",
    "slug": "maase",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F4A300",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maase.customerapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maase uses your location to find home cooks within 3km."
      }
    },
    "android": {
      "package": "com.maase.customerapp",
      "adaptiveIcon": {
        "backgroundColor": "#F4A300"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": ["expo-font", "expo-location"]
  }
}
