{
  "expo": {
    "name": "Maase",
    "slug": "maase",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4A300"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maase.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maase uses your location to find home cooks within 3km of you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4A300"
      },
      "package": "com.maase.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-font",
      "expo-location"
    ]
  }
}
